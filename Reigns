<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>華語生存戰：校園日常</title>
    <style>
        :root {
            --bg-color: #f0f2f5;
            --card-bg: #ffffff;
            --event-bg: #ffeaa7; /* 事件卡特別背景色 */
            --text-main: #2d3436;
            --btn-left: #ff7675;
            --btn-right: #74b9ff;
            --btn-event: #fdcb6e;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-color);
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            color: var(--text-main);
        }
        #game-container {
            width: 100%;
            max-width: 420px;
            background: var(--card-bg);
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.15);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            height: 90vh;
            max-height: 750px;
            position: relative;
        }
        /* 頂部數值區 */
        #stats-board {
            display: flex;
            justify-content: space-around;
            padding: 15px;
            background: #2d3436;
            color: white;
            font-size: 1.2rem;
            transition: background 0.3s;
        }
        .stat { display: flex; flex-direction: column; align-items: center; }
        .stat-icon { font-size: 1.6rem; }
        .stat-value { font-weight: bold; margin-top: 5px; }

        /* 遊戲進度與標籤 */
        #status-bar {
            display: flex;
            justify-content: space-between;
            padding: 10px 20px;
            font-size: 0.9rem;
            background: #dfe6e9;
            font-weight: bold;
        }
        #card-type { color: #0984e3; }

        /* 卡片顯示區 */
        #card-area {
            flex-grow: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 25px;
            text-align: center;
            transition: background 0.3s;
        }
        #scenario-text {
            font-size: 1.6rem;
            line-height: 2.8rem;
            font-weight: 500;
        }
        ruby { ruby-align: center; }
        rt { font-size: 0.85rem; color: #d63031; font-weight: bold; }

        /* 底部按鈕區 */
        #controls { display: flex; height: 130px; }
        .choice-btn {
            flex: 1;
            border: none;
            font-size: 1.2rem;
            font-weight: bold;
            color: white;
            cursor: pointer;
            padding: 15px;
            transition: background 0.2s, opacity 0.2s;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        .choice-btn:active { opacity: 0.8; }
        #btn-left { background-color: var(--btn-left); }
        #btn-right { background-color: var(--btn-right); }
        #btn-event { 
            background-color: var(--btn-event); 
            display: none; /* 預設隱藏，事件發生時才顯示 */
            color: #2d3436;
            width: 100%;
        }

        /* 結束畫面 */
        #game-over {
            position: absolute; top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(255,255,255,0.95);
            display: none; flex-direction: column;
            justify-content: center; align-items: center;
            text-align: center; padding: 20px; z-index: 10;
        }
        #game-over h2 { font-size: 2.5rem; color: #d63031; margin-bottom: 10px; }
        #restart-btn {
            margin-top: 30px; padding: 12px 25px;
            font-size: 1.2rem; background: #2d3436; color: white;
            border: none; border-radius: 10px; cursor: pointer;
        }
    </style>
</head>
<body>

<div id="game-container">
    <div id="stats-board">
        <div class="stat" title="體力"><span class="stat-icon">⚡</span><span id="stat-energy" class="stat-value">50</span></div>
        <div class="stat" title="金錢"><span class="stat-icon">💰</span><span id="stat-money" class="stat-value">50</span></div>
        <div class="stat" title="人際"><span class="stat-icon">🤝</span><span id="stat-social" class="stat-value">50</span></div>
        <div class="stat" title="學業"><span class="stat-icon">📚</span><span id="stat-academic" class="stat-value">50</span></div>
    </div>
    
    <div id="status-bar">
        <span id="card-type">日常選擇</span>
        <span>第 <span id="current-day">1</span> 天 / 共 30 天</span>
    </div>

    <div id="card-area">
        <div id="scenario-text">載入中...</div>
    </div>

    <div id="controls">
        <button id="btn-left" class="choice-btn" onclick="makeChoice('left')">左</button>
        <button id="btn-right" class="choice-btn" onclick="makeChoice('right')">右</button>
        <button id="btn-event" class="choice-btn" onclick="makeChoice('event')">確認</button>
    </div>

    <div id="game-over">
        <h2 id="end-title">遊戲結束</h2>
        <p id="end-message" style="font-size: 1.2rem; line-height: 1.8;">原因</p>
        <button id="restart-btn" onclick="initGame()">再玩一次</button>
    </div>
</div>

<script>
    let stats = { energy: 50, money: 50, social: 50, academic: 50 };
    let currentDay = 1;
    const maxDays = 30;
    let currentCard = null;

    // --- 卡片資料庫 ---
    // 一般卡片：需要左右二選一，會產生複雜的多項數值變化
    const normalCards = [
        // 【A. 校園與學習】
        {
            text: "明天有很重要的華語<ruby>報<rt>bào</rt>告<rt>gào</rt></ruby>，但朋友約你去逛街。",
            left: { text: "去逛街！放鬆一下", impact: { energy: -10, money: -20, social: +20, academic: -25 } },
            right: { text: "不去，我要準備報告", impact: { energy: -15, money: 0, social: -10, academic: +20 } }
        },
        {
            text: "上課時，你發現自己忘記帶課本了...",
            left: { text: "跟旁邊的同學借", impact: { energy: 0, money: 0, social: +10, academic: +5 } },
            right: { text: "假裝有帶，發呆", impact: { energy: +5, money: 0, social: 0, academic: -15 } }
        },
        // 【B. 飲食與點餐】
        {
            text: "午餐時間，學校<ruby>餐<rt>cān</rt>廳<rt>tīng</rt></ruby>人很多，要排隊很久。",
            left: { text: "去便利商店隨便買", impact: { energy: +10, money: -10, social: 0, academic: +5 } },
            right: { text: "跟同學一起排隊聊天", impact: { energy: -5, money: -15, social: +15, academic: -5 } }
        },
        {
            text: "你想喝飲料，同學推薦一家很貴的網美咖啡廳。",
            left: { text: "走吧！我請客！", impact: { energy: +5, money: -30, social: +25, academic: 0 } },
            right: { text: "太貴了，我喝水就好", impact: { energy: 0, money: +10, social: -10, academic: 0 } }
        },
        // 【C. 購物與交通】
        {
            text: "你要搭<ruby>捷<rt>jié</rt>運<rt>yùn</rt></ruby>回家，發現悠遊卡裡面沒錢了。",
            left: { text: "花時間去加值", impact: { energy: -5, money: -10, social: 0, academic: 0 } },
            right: { text: "直接搭計程車回家", impact: { energy: +10, money: -35, social: 0, academic: +5 } }
        },
        // 【D. 社交與生活】
        {
            text: "週末到了，你想怎麼安排時間？",
            left: { text: "去圖書館打工", impact: { energy: -20, money: +30, social: -5, academic: +5 } },
            right: { text: "參加社團活動", impact: { energy: -15, money: -10, social: +25, academic: 0 } }
        }
    ];

    // 事件卡片：沒有選擇權，只能按「確認」，通常是突發狀況
    const eventCards = [
        {
            text: "【突發事件】<br>最近天氣變冷，你不小心<ruby>感<rt>gǎn</rt>冒<rt>mào</rt></ruby>了...",
            btnText: "咳咳...只能多休息了",
            impact: { energy: -25, money: -15, social: -10, academic: -10 }
        },
        {
            text: "【好運降臨】<br>你在舊外套的口袋裡發現了 500 元！",
            btnText: "太幸運了！",
            impact: { energy: +5, money: +30, social: 0, academic: 0 }
        },
        {
            text: "【突發事件】<br>颱風天停班停課！不用去學校了！",
            btnText: "耶！在家睡覺！",
            impact: { energy: +30, money: 0, social: -5, academic: -15 }
        }
    ];

    // --- 遊戲邏輯 ---
    function initGame() {
        stats = { energy: 50, money: 50, social: 50, academic: 50 };
        currentDay = 1;
        document.getElementById("game-over").style.display = "none";
        updateUI();
        drawCard();
    }

    function drawCard() {
        // 20% 機率抽到事件卡，80% 一般卡
        const isEvent = Math.random() < 0.2; 
        
        if (isEvent) {
            // 處理事件卡介面
            const randomIndex = Math.floor(Math.random() * eventCards.length);
            currentCard = { ...eventCards[randomIndex], isEvent: true };
            
            document.getElementById("card-type").innerText = "⚠️ 突發事件";
            document.getElementById("card-area").style.background = "var(--event-bg)";
            document.getElementById("scenario-text").innerHTML = currentCard.text;
            
            document.getElementById("btn-left").style.display = "none";
            document.getElementById("btn-right").style.display = "none";
            document.getElementById("btn-event").style.display = "block";
            document.getElementById("btn-event").innerHTML = currentCard.btnText;
        } else {
            // 處理一般卡介面
            const randomIndex = Math.floor(Math.random() * normalCards.length);
            currentCard = { ...normalCards[randomIndex], isEvent: false };
            
            document.getElementById("card-type").innerText = "日常選擇";
            document.getElementById("card-area").style.background = "transparent";
            document.getElementById("scenario-text").innerHTML = currentCard.text;
            
            document.getElementById("btn-left").style.display = "block";
            document.getElementById("btn-right").style.display = "block";
            document.getElementById("btn-event").style.display = "none";
            
            document.getElementById("btn-left").innerHTML = currentCard.left.text;
            document.getElementById("btn-right").innerHTML = currentCard.right.text;
        }
    }

    function makeChoice(direction) {
        let impactObj;
        
        if (currentCard.isEvent) {
            impactObj = currentCard.impact;
        } else {
            impactObj = direction === 'left' ? currentCard.left.impact : currentCard.right.impact;
        }
        
        // 套用多項數值變化
        stats.energy += impactObj.energy;
        stats.money += impactObj.money;
        stats.social += impactObj.social;
        stats.academic += impactObj.academic;

        // 限制在 0 ~ 100
        for (let key in stats) {
            if (stats[key] > 100) stats[key] = 100;
        }

        currentDay++;
        updateUI();
        checkGameEnd();
    }

    function updateUI() {
        document.getElementById("stat-energy").innerText = stats.energy;
        document.getElementById("stat-money").innerText = stats.money;
        document.getElementById("stat-social").innerText = stats.social;
        document.getElementById("stat-academic").innerText = stats.academic;
        document.getElementById("current-day").innerText = currentDay;
    }

    function checkGameEnd() {
        let over = false;
        let message = "";

        if (stats.energy <= 0) { over = true; message = "你太累了，在課堂上暈倒被送進醫院。<br><strong>(體力歸零)</strong>"; }
        else if (stats.money <= 0) { over = true; message = "你身無分文，只能打電話向家人求救。<br><strong>(金錢歸零)</strong>"; }
        else if (stats.social <= 0) { over = true; message = "你完全沒有朋友，感到非常孤單而休學。<br><strong>(人際歸零)</strong>"; }
        else if (stats.academic <= 0) { over = true; message = "你的成績太差，被學校退學了。<br><strong>(學業歸零)</strong>"; }
        
        if (!over && currentDay > maxDays) {
            showGameOver("🎉 恭喜過關！", "你成功規劃了校園生活，<br>華語和生存技能都滿分！");
            return;
        }

        if (over) { showGameOver("💀 遊戲結束", message); } 
        else { drawCard(); }
    }

    function showGameOver(title, message) {
        document.getElementById("end-title").innerText = title;
        document.getElementById("end-message").innerHTML = message;
        document.getElementById("game-over").style.display = "flex";
    }

    initGame();
</script>

</body>
</html>
